[flake8]
max-line-length = 120
exclude = 
    .git,
    __pycache__,
    myenv,
    build,
    dist,
    *.egg-info,
    .github,
    private/pb/*_pb2.py,
    private/pb/*_pb2_grpc.py
ignore = 
    E203,
    E501,
    W503,
    E402,
    E266,
    E722,
    F401,
    F541,
    F811,
    F841,
    W293,
    C901
per-file-ignores =
    __init__.py:F401,F403
max-complexity = 15

